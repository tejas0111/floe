# ---------------------------
# Core Server
# ---------------------------
# MANDATORY
PORT=3001

# MANDATORY
NODE_ENV=development

# ---------------------------
# Storage + State
# ---------------------------
# MANDATORY
UPLOAD_TMP_DIR=/home/tejas/Floe/apps/api/tmp/upload/

# MANDATORY
UPSTASH_REDIS_REST_URL=https://<your-upstash-url>.upstash.io

# MANDATORY
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# ---------------------------
# Walrus
# ---------------------------
# MANDATORY
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# MANDATORY
WALRUS_AGGREGATOR_URL=https://walrus-testnet-aggregator.nodes.guru

# OPTIONAL (comma-separated list)
WALRUS_AGGREGATOR_FALLBACK_URLS=https://agg-1.example.com,https://agg-2.example.com

# OPTIONAL - ask Walrus publisher to transfer Blob object to this address
WALRUS_SEND_OBJECT_TO=0x1111111111111111111111111111111111111111111111111111111111111111

# OPTIONAL
WALRUS_READ_TIMEOUT_MS=600000

# OPTIONAL
WALRUS_READ_MAX_RETRIES=2

# OPTIONAL
WALRUS_READ_RETRY_DELAY_MS=250

# ---------------------------
# Sui
# ---------------------------
# MANDATORY (mainnet | testnet)
FLOE_NETWORK=testnet

# MANDATORY
SUI_PRIVATE_KEY=suiprivkey...

# OPTIONAL (auto-defaults by FLOE_NETWORK if omitted)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# MANDATORY
SUI_PACKAGE_ID=0x<your-package-id>

# ---------------------------
# Upload Limits
# ---------------------------
# OPTIONAL
FLOE_MAX_FILE_SIZE_BYTES=16106127360

# OPTIONAL
FLOE_MAX_TOTAL_CHUNKS=200000

# OPTIONAL
FLOE_MAX_ACTIVE_UPLOADS=100

# OPTIONAL
FLOE_UPLOAD_SESSION_TTL_MS=21600000

# OPTIONAL
FLOE_CHUNK_MIN_BYTES=262144

# OPTIONAL
FLOE_CHUNK_MAX_BYTES=20971520

# OPTIONAL
FLOE_CHUNK_DEFAULT_BYTES=2097152

# OPTIONAL
FLOE_GC_INTERVAL_MS=300000

# OPTIONAL
FLOE_GC_GRACE_MS=900000

# ---------------------------
# Tiered Auth/Limits (Scaffold)
# ---------------------------
# OPTIONAL
FLOE_RATE_LIMIT_WINDOW_SECONDS=60

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CONTROL_PUBLIC=5

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CONTROL_AUTH=120

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CHUNK_PUBLIC=30

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CHUNK_AUTH=1200

# OPTIONAL
FLOE_RATE_LIMIT_FILE_READ_PUBLIC=120

# OPTIONAL
FLOE_RATE_LIMIT_FILE_READ_AUTH=1200

# OPTIONAL
FLOE_PUBLIC_MAX_FILE_SIZE_BYTES=104857600

# OPTIONAL
FLOE_AUTH_MAX_FILE_SIZE_BYTES=16106127360

# OPTIONAL (0|1) - enforce stored upload owner on chunk/status/complete/cancel
FLOE_ENFORCE_UPLOAD_OWNER=0

# OPTIONAL - fallback owner stored in FileMeta when request has no owner header
FLOE_DEFAULT_OWNER_ADDRESS=0x1111111111111111111111111111111111111111111111111111111111111111

# ---------------------------
# Read/Response Behavior
# ---------------------------
# OPTIONAL (0|1)
FLOE_EXPOSE_BLOB_ID=0

# OPTIONAL
FLOE_FILE_FIELDS_CACHE_TTL_MS=86400000

# OPTIONAL
FLOE_STREAM_MAX_RANGE_BYTES=67108864

# OPTIONAL (0|1) - verbose walrus upload metrics log line per finalize attempt
FLOE_LOG_WALRUS_METRICS=0

# ---------------------------
# HTTP/CORS
# ---------------------------
# OPTIONAL (empty means CORS disabled)
FLOE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
