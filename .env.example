# ---------------------------
# Core Server
# ---------------------------
# MANDATORY
PORT=3001

# MANDATORY
NODE_ENV=development

# ---------------------------
# Storage + State
# ---------------------------
# MANDATORY
# Use a persistent writable path. Floe still assembles temporary files here even when chunk staging uses S3.
UPLOAD_TMP_DIR=/var/lib/floe/upload

# OPTIONAL - chunk staging backend: s3 (MinIO/R2/S3 compatible) | disk
FLOE_CHUNK_STORE_MODE=s3

# MANDATORY when FLOE_CHUNK_STORE_MODE=s3
FLOE_S3_BUCKET=floe-staging

# OPTIONAL
FLOE_S3_REGION=us-east-1

# OPTIONAL - required for MinIO/self-hosted S3
FLOE_S3_ENDPOINT=http://127.0.0.1:9000

# OPTIONAL (0|1) - true for MinIO path-style URLs
FLOE_S3_FORCE_PATH_STYLE=1

# MANDATORY when FLOE_CHUNK_STORE_MODE=s3 (unless IAM role env is used)
FLOE_S3_ACCESS_KEY_ID=minioadmin
FLOE_S3_SECRET_ACCESS_KEY=minioadmin

# OPTIONAL
FLOE_S3_SESSION_TOKEN=

# OPTIONAL - prefix for chunk objects
FLOE_S3_PREFIX=floe/chunks

# OPTIONAL (0|1) - auto create bucket if missing
FLOE_S3_CREATE_BUCKET_IF_MISSING=0

# OPTIONAL - redis provider: upstash (default) or native
FLOE_REDIS_PROVIDER=upstash

# REQUIRED when FLOE_REDIS_PROVIDER=upstash
UPSTASH_REDIS_REST_URL=https://<your-upstash-url>.upstash.io

# REQUIRED when FLOE_REDIS_PROVIDER=upstash
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# REQUIRED when FLOE_REDIS_PROVIDER=native
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------
# Postgres (Read Model)
# ---------------------------
# OPTIONAL (recommended for beta/prod read model and indexing)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# OPTIONAL
FLOE_POSTGRES_POOL_MAX=10

# OPTIONAL
FLOE_POSTGRES_IDLE_TIMEOUT_MS=30000

# OPTIONAL
FLOE_POSTGRES_CONNECT_TIMEOUT_MS=10000

# OPTIONAL (0|1) - fail startup when DATABASE_URL is configured but unavailable
FLOE_POSTGRES_REQUIRED=0

# ---------------------------
# Walrus
# ---------------------------
# MANDATORY
WALRUS_AGGREGATOR_URL=https://walrus-testnet-aggregator.nodes.guru

# OPTIONAL (comma-separated list)
WALRUS_AGGREGATOR_FALLBACK_URLS=https://agg-1.example.com,https://agg-2.example.com

# OPTIONAL - walrus upload mode: sdk | cli
FLOE_WALRUS_STORE_MODE=sdk

# MANDATORY when FLOE_WALRUS_STORE_MODE=sdk
# Can be public or self-hosted publisher-compatible API base URL.
FLOE_WALRUS_SDK_BASE_URL=https://publisher.walrus-testnet.walrus.space

# OPTIONAL - used by sdk mode to transfer Blob object to a target address
WALRUS_SEND_OBJECT_TO=0x1111111111111111111111111111111111111111111111111111111111111111

# MANDATORY when FLOE_WALRUS_STORE_MODE=cli
FLOE_WALRUS_CLI_BIN=walrus

# OPTIONAL
WALRUS_READ_TIMEOUT_MS=600000

# OPTIONAL
WALRUS_READ_MAX_RETRIES=2

# OPTIONAL
WALRUS_READ_RETRY_DELAY_MS=250

# OPTIONAL - larger first fetch for cold full-object playback
FLOE_STREAM_INITIAL_SEGMENT_BYTES=33554432

# OPTIONAL - full-object cache threshold for smaller reads
FLOE_STREAM_INLINE_FULL_MAX_BYTES=33554432

# OPTIONAL - stream cache eviction TTL
FLOE_STREAM_CACHE_TTL_MS=1800000

# OPTIONAL - max bytes across local stream cache files.
# Larger values can improve warm reads and help shield Walrus/origin when a CDN or reverse proxy
# repeatedly requests hot content through this same Floe instance.
# This is still a per-instance local cache, not a global edge cache.
FLOE_STREAM_CACHE_MAX_BYTES=53687091200

# OPTIONAL - global concurrent stream-cache fills
FLOE_STREAM_CACHE_FILL_CONCURRENCY=4

# OPTIONAL - walrus upload request timeout
FLOE_WALRUS_UPLOAD_TIMEOUT_MS=1200000

# OPTIONAL - walrus upload retry policy
FLOE_WALRUS_UPLOAD_MAX_RETRIES=3
FLOE_WALRUS_UPLOAD_RETRY_DELAY_MS=2000

# OPTIONAL - walrus publish queue throughput
FLOE_WALRUS_QUEUE_CONCURRENCY=4
FLOE_WALRUS_QUEUE_INTERVAL_CAP=4
FLOE_WALRUS_QUEUE_INTERVAL_MS=1000

# ---------------------------
# Sui
# ---------------------------
# MANDATORY (mainnet | testnet)
FLOE_NETWORK=testnet

# MANDATORY
SUI_PRIVATE_KEY=suiprivkey...

# OPTIONAL (auto-defaults by FLOE_NETWORK if omitted)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# MANDATORY
SUI_PACKAGE_ID=0x<your-package-id>

# ---------------------------
# Upload Limits
# ---------------------------
# OPTIONAL
FLOE_MAX_FILE_SIZE_BYTES=16106127360

# OPTIONAL
FLOE_MAX_TOTAL_CHUNKS=200000

# OPTIONAL
FLOE_MAX_ACTIVE_UPLOADS=100

# OPTIONAL
FLOE_UPLOAD_SESSION_TTL_MS=21600000

# OPTIONAL
FLOE_CHUNK_MIN_BYTES=262144

# OPTIONAL
FLOE_CHUNK_MAX_BYTES=20971520

# OPTIONAL
FLOE_CHUNK_DEFAULT_BYTES=2097152

# OPTIONAL
FLOE_GC_INTERVAL_MS=300000

# OPTIONAL
FLOE_GC_GRACE_MS=900000

# OPTIONAL - finalize worker process settings
FLOE_FINALIZE_CONCURRENCY=4
FLOE_FINALIZE_TIMEOUT_MS=1800000
FLOE_FINALIZE_RETRY_MS=2000
FLOE_FINALIZE_RETRY_MAX_MS=30000
FLOE_FINALIZE_RETRYABLE_FAILURE_BASE_MS=2000
FLOE_FINALIZE_RETRYABLE_FAILURE_MAX_MS=30000
FLOE_FINALIZE_RETRYABLE_FAILURE_MAX_ATTEMPTS=4
FLOE_FINALIZE_QUEUE_STUCK_AGE_MS=300000
FLOE_FINALIZE_DRAIN_INTERVAL_MS=500
FLOE_FINALIZE_QUEUE_MAX_DEPTH=5000
FLOE_FINALIZE_STATUS_POLL_MS=2000

# ---------------------------
# Auth + Limits
# ---------------------------
# OPTIONAL - public | hybrid | private
FLOE_AUTH_MODE=hybrid

# OPTIONAL - env-backed API keys for verified auth
# Example value shown on multiple lines for readability. In a real .env file this must be valid JSON on one line.
FLOE_API_KEYS_JSON=[
  {"id":"local-dev","secret":"replace-with-long-random-secret","owner":"0xf35568c562fd25dccd58e4e9240d8a6f864de0a9854ddd1f7d8aa6ff5f9722a4","tier":"authenticated","scopes":["*"]}
]

# OPTIONAL
FLOE_RATE_LIMIT_WINDOW_SECONDS=60

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CONTROL_PUBLIC=5

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CONTROL_AUTH=120

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CHUNK_PUBLIC=30

# OPTIONAL
FLOE_RATE_LIMIT_UPLOAD_CHUNK_AUTH=1200

# OPTIONAL
FLOE_RATE_LIMIT_FILE_META_PUBLIC=240

# OPTIONAL
FLOE_RATE_LIMIT_FILE_META_AUTH=2400

# OPTIONAL
FLOE_RATE_LIMIT_FILE_STREAM_PUBLIC=120

# OPTIONAL
FLOE_RATE_LIMIT_FILE_STREAM_AUTH=1200

# OPTIONAL - public stream base URL for CDN or dedicated read host
FLOE_PUBLIC_STREAM_BASE_URL=

# OPTIONAL
FLOE_PUBLIC_MAX_FILE_SIZE_BYTES=104857600

# OPTIONAL
FLOE_AUTH_MAX_FILE_SIZE_BYTES=16106127360

# OPTIONAL (0|1) - enforce stored upload owner on chunk/status/complete/cancel
FLOE_ENFORCE_UPLOAD_OWNER=0

# OPTIONAL - fallback owner stored in FileMeta when no verified principal owner is available
FLOE_DEFAULT_OWNER_ADDRESS=0xf35568c562fd25dccd58e4e9240d8a6f864de0a9854ddd1f7d8aa6ff5f9722a4

# ---------------------------
# Read/Response Behavior
# ---------------------------
# OPTIONAL (0|1)
FLOE_EXPOSE_BLOB_ID=0

# OPTIONAL - in-process hot cache for metadata/manifest/stream lookups
FLOE_FILE_FIELDS_MEMORY_CACHE_TTL_MS=60000

# OPTIONAL
FLOE_FILE_FIELDS_MEMORY_CACHE_MAX_ENTRIES=5000

# OPTIONAL (0|1) - log metadata source + lookup duration
FLOE_FILE_FIELDS_DEBUG=0

# OPTIONAL
FLOE_STREAM_MAX_RANGE_BYTES=67108864

# OPTIONAL - stitched segment size used for media playback reads
FLOE_STREAM_MEDIA_SEGMENT_BYTES=8388608

# OPTIONAL (0|1) - verbose walrus upload metrics log line per finalize attempt
FLOE_LOG_WALRUS_METRICS=0

# ---------------------------
# HTTP/CORS
# ---------------------------
# OPTIONAL (empty means CORS disabled)
FLOE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------
# Observability
# ---------------------------
# OPTIONAL (0|1) - expose /metrics endpoint
FLOE_ENABLE_METRICS=1

# MANDATORY when FLOE_ENABLE_METRICS=1 (use a strong random token)
FLOE_METRICS_TOKEN=change-me-strong-random-token
