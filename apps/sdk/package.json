{
  "name": "@floehq/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Floe upload and file API",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "smoke": "npm run build && node ./examples/smoke.mjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
